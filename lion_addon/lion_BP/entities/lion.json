                                    "subject": "other",
                                    "value": "sheep"
                                },
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "cow"
                                },
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "pig"
                                },
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "rabbit"
                                }
                            ]
                        },
                        "max_dist": 20,
                        "must_see": true,
                        "sprint_speed_multiplier": 1.4
                    }
                ]
            },
            "minecraft:behavior.melee_attack": {
                "priority": 3,
                "speed_multiplier": 1.4,
