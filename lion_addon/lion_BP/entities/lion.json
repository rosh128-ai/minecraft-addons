                    "on_death": "query.last_hit_by_player ? 1 + 2 * Math.Random(1, 3) : 0"
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": ["lion", "animal", "mob"]
            },
            "minecraft:collision_box": {
