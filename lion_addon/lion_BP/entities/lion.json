            "minecraft:health": {
                "value": 20,
                "max": 30
            },
            "minecraft:attack": {
                "damage": 4
            },
            "minecraft:movement": {
                "value": 0.35
            },
            "minecraft:movement.basic": {},
            "minecraft:navigation.walk": {
                "can_path_over_water": false,
